# API Keys - 复制为 .env 并填入你的密钥

# OpenAI
OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# 阿里Dashscope
DASHSCOPE_API_KEY=your_dashscope_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key_here

# Email SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# 交易所API (TradeAI)
EXCHANGE_API_KEY=your_exchange_key
EXCHANGE_API_SECRET=your_exchange_secret

# SEO工具API
SEO_API_KEY=your_seo_api_key

# 社媒平台API
X_API_KEY=your_twitter_key
X_API_SECRET=your_twitter_secret
WECHAT_APP_ID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
